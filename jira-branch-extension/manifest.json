{
  "manifest_version": 3,
  "name": "Jira Branch Generator",
  "version": "1.2.0",
  "description": "Auto-detect Jira ticket IDs and generate git branch names instantly. Supports Bitbucket and GitHub integration.",
  "key": "",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "*://*.atlassian.net/*",
    "*://*.jira.com/*",
    "*://bitbucket.org/*",
    "*://api.bitbucket.org/*",
    "*://api.github.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.atlassian.net/*", "*://*.jira.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
